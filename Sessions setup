-- ══════════════════════════════════════════════════════════════
--  SESSION MAP — SQL SETUP
--  Run this in Supabase → SQL Editor → New Query
-- ══════════════════════════════════════════════════════════════

-- 1. Create the sessions table
CREATE TABLE sessions (
  id          TEXT PRIMARY KEY,  -- Stores the date in YYYY-MM-DD
  status      TEXT NOT NULL,     -- "open" or "closed"
  opened_at   TIMESTAMPTZ,
  opened_by   TEXT,              -- "manual" or "auto"
  closed_at   TIMESTAMPTZ,
  closed_by   TEXT,              -- "manual" or "auto"
  order_count INTEGER DEFAULT 0,
  revenue     INTEGER DEFAULT 0
);

-- 2. Enable Row Level Security
ALTER TABLE sessions ENABLE ROW LEVEL SECURITY;

-- 3. Allow anyone to read
CREATE POLICY "Anyone can read sessions"
  ON sessions FOR SELECT
  USING (true);

-- 4. Allow anyone to insert
CREATE POLICY "Anyone can insert sessions"
  ON sessions FOR INSERT
  WITH CHECK (true);

-- 5. Allow anyone to update
CREATE POLICY "Anyone can update sessions"
  ON sessions FOR UPDATE
  USING (true);

-- 6. Allow anyone to delete (if needed)
CREATE POLICY "Anyone can delete sessions"
  ON sessions FOR DELETE
  USING (true);